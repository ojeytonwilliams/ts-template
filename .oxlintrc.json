{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "eslint",
    "import",
    "typescript",
    "react",
    "oxc",
    "promise",
    "vitest"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "pedantic": "error",
    "perf": "error",
    "style": "error"
  },
  "options": {
    "typeAware": true,
    "typeCheck": true
  },
  "ignorePatterns": ["dist/**"],
  "rules": {
    "id-length": "off",
    "import/no-named-export": "off",
    "import/no-default-export": "error",
    "vitest/prefer-describe-function-title": "error",
    "jest/valid-title": "off"
  },
}
